---
import { getCollection } from 'astro:content';
import { WebOS } from '../components/os/WebOS';
import '../styles/global.css';

// Fetch all collections
const memories = await getCollection('memories');
const motivation = await getCollection('motivation');
const accomplishments = await getCollection('accomplishments');
const awards = await getCollection('awards');
const honnies = await getCollection('honnies');
const about = await getCollection('about');
const innovations = await getCollection('innovations');
const future = await getCollection('future');

// Helper to bundle all entries for the Timeline
const allEntries = [
  ...memories.map(e => ({ ...e, collection: 'memories' })),
  ...motivation.map(e => ({ ...e, collection: 'motivation' })),
  ...accomplishments.map(e => ({ ...e, collection: 'accomplishments' })),
  ...awards.map(e => ({ ...e, collection: 'awards' })),
  ...honnies.map(e => ({ ...e, collection: 'honnies' })),
  ...about.map(e => ({ ...e, collection: 'about' })),
  ...innovations.map(e => ({ ...e, collection: 'innovations' })),
  ...future.map(e => ({ ...e, collection: 'future' })),
];

const collections = {
  memories,
  motivation,
  accomplishments,
  awards,
  honnies,
  about,
  innovations,
  future,
  allEntries,
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/PIDEA/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>MindOS | Neural Hub</title>
    <!-- Load Three.js globally for Vanta -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r134/three.min.js"></script>
  </head>
  <body>
    <!-- Client:only directive is crucial for React apps that use browser APIs (window, etc) -->
    <WebOS client:only="react" collections={collections} />
  </body>
</html>
