---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <main
    class="flex flex-col items-center justify-center min-h-screen bg-slate-950 text-white font-sans"
  >
    <!-- The Brand Name -->
    <h1
      id="brand"
      class="text-8xl font-black tracking-tighter text-transparent bg-clip-text bg-linear-to-br from-white to-slate-500"
    >
      PIDEA
    </h1>

    <!-- The Slogan -->
    <p
      id="slogan"
      class="mt-4 text-xl text-slate-400 font-light tracking-[0.2em] uppercase"
    >
      Innovation is the future
    </p>
  </main>
</Layout>

<script>
  import { gsap } from "gsap";

  // Visually perfect entrance animation
  const tl = gsap.timeline();

  tl.from("#brand", {
    y: 50,
    opacity: 0,
    duration: 1.5,
    ease: "expo.out",
  }).from(
    "#slogan",
    {
      opacity: 0,
      letterSpacing: "0em",
      duration: 2,
      ease: "power2.out",
    },
    "-=0.5",
  );
</script>
