---
export interface Props {
  id: string;
  title: string;
  initialX?: number;
  initialY?: number;
  width?: string;
  height?: string;
  hidden?: boolean;
}

const { id, title, initialX = 50, initialY = 50, width = "600px", height = "400px", hidden = true } = Astro.props;
---

<div id={id} class={`os-window fixed z-50 flex flex-col rounded-xl overflow-hidden shadow-2xl border border-white/10 ${hidden ? 'hidden opacity-0 scale-95' : ''}`}
     style={`left: ${initialX}px; top: ${initialY}px; width: ${width}; height: ${height}; background: rgba(20, 20, 25, 0.75); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);`}>

  <!-- Title Bar -->
  <div class="window-header h-8 bg-white/5 border-b border-white/10 flex items-center px-4 cursor-grab active:cursor-grabbing select-none shrink-0 relative">
    <!-- Window Controls -->
    <div class="flex gap-2 absolute left-4">
      <button class="close-btn w-3 h-3 rounded-full bg-red-500 hover:bg-red-600 border border-red-600/50 flex items-center justify-center group" aria-label="Close">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-2 w-2 text-black opacity-0 group-hover:opacity-100" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" /></svg>
      </button>
      <button class="min-btn w-3 h-3 rounded-full bg-yellow-500 hover:bg-yellow-600 border border-yellow-600/50 flex items-center justify-center group" aria-label="Minimize">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-2 w-2 text-black opacity-0 group-hover:opacity-100" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M3 10a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1z" clip-rule="evenodd" /></svg>
      </button>
      <button class="max-btn w-3 h-3 rounded-full bg-green-500 hover:bg-green-600 border border-green-600/50 flex items-center justify-center group" aria-label="Maximize">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-2 w-2 text-black opacity-0 group-hover:opacity-100" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M3 4a1 1 0 011-1h4a1 1 0 010 2H6.414l2.293 2.293a1 1 0 01-1.414 1.414L5 6.414V8a1 1 0 01-2 0V4zm9 1a1 1 0 110-2h4a1 1 0 011 1v4a1 1 0 11-2 0V6.414l-2.293 2.293a1 1 0 11-1.414-1.414L13.586 5H12zm-9 7a1 1 0 112 0v1.586l2.293-2.293a1 1 0 011.414 1.414L6.414 15H8a1 1 0 110 2H4a1 1 0 01-1-1v-4zm13-1a1 1 0 011 1v4a1 1 0 01-1 1h-4a1 1 0 110-2h1.586l-2.293-2.293a1 1 0 011.414-1.414L15 13.586V12a1 1 0 011-1z" clip-rule="evenodd" /></svg>
      </button>
    </div>
    <!-- Title -->
    <div class="flex-1 text-center text-xs font-semibold text-gray-300 tracking-wide">{title}</div>
  </div>

  <!-- Content Area -->
  <div class="window-content flex-1 overflow-auto p-4 text-white">
    <slot />
  </div>
</div>

<script>
  import { gsap } from "gsap";
  import { Draggable } from "gsap/Draggable";

  // Register Draggable plugin
  gsap.registerPlugin(Draggable);

  document.addEventListener("DOMContentLoaded", () => {
    // Make windows draggable
    const windows = document.querySelectorAll('.os-window');

    let zIndexCounter = 100;

    windows.forEach(win => {
      // Setup dragging
      Draggable.create(win, {
        type: "x,y",
        handle: ".window-header",
        bounds: "body",
        onPress: function() {
          zIndexCounter++;
          gsap.set(win, { zIndex: zIndexCounter });
        }
      });

      // Bring to front on click
      win.addEventListener('mousedown', () => {
        zIndexCounter++;
        gsap.set(win, { zIndex: zIndexCounter });
      });

      // Close button logic (just hides it)
      const closeBtn = win.querySelector('.close-btn');
      closeBtn?.addEventListener('click', (e) => {
        e.stopPropagation();
        gsap.to(win, { opacity: 0, scale: 0.9, duration: 0.2, onComplete: () => {
          win.classList.add('hidden');
        }});
      });

      // Minimize button logic
      const minBtn = win.querySelector('.min-btn');
      minBtn?.addEventListener('click', (e) => {
        e.stopPropagation();
        // Animate down to dock area roughly
        const dockY = window.innerHeight;
        gsap.to(win, {
          y: dockY,
          scale: 0.2,
          opacity: 0,
          duration: 0.4,
          ease: "power2.in",
          onComplete: () => {
            win.classList.add('hidden');
            // reset transform for when it opens again
            gsap.set(win, { y: 0, scale: 1 });
          }
        });
      });
    });

    // Listen for custom open-app events from Dock
    window.addEventListener('open-app', (e) => {
      const { appId } = (e as CustomEvent).detail;
      const targetWindow = document.getElementById(`window-${appId}`);

      if (targetWindow) {
        targetWindow.classList.remove('hidden');
        zIndexCounter++;
        gsap.set(targetWindow, { zIndex: zIndexCounter });

        // Pop in animation
        gsap.fromTo(targetWindow,
          { opacity: 0, scale: 0.8 },
          { opacity: 1, scale: 1, duration: 0.3, ease: "back.out(1.5)" }
        );
      }
    });
  });
</script>